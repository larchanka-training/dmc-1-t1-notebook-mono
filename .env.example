# =============================================================
# JS Notebook — переменные окружения
# Скопируй этот файл: cp .env.example .env
# Заполни секции с пометкой [REQUIRED] перед запуском
# =============================================================

# ----- PostgreSQL -----------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme        # [REQUIRED] смени перед первым запуском
POSTGRES_DB=wiki

# ----- Строка подключения к БД ----------------------------
# Используется API-сервисом; должна совпадать с POSTGRES_* выше
DATABASE_URL=postgresql://admin:changeme@postgres:5432/wiki  # [REQUIRED]

# ----- pgAdmin --------------------------------------------
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=changeme         # [REQUIRED]

# ----- API ------------------------------------------------
APP_NAME=JS Notebook
APP_ENV=dev                        # dev | staging | prod
API_PREFIX=/api/v1

# ----- OAuth (заполняется при настройке OAuth-провайдера) --
OAUTH_CLIENT_ID=                   # [REQUIRED для OAuth]
OAUTH_CLIENT_SECRET=               # [REQUIRED для OAuth] — сгенерируй новый, старый скомпрометирован

# ----- Время жизни токенов --------------------------------
TOKEN_TTL_SECONDS=86400            # 24 часа
SESSION_TTL_SECONDS=604800         # 7 дней

# ----- OpenTelemetry → Aspire Dashboard -------------------
# false = OTel выключен (безопасно для запуска без Aspire)
OTEL_ENABLED=false
OTEL_ENDPOINT=http://aspire-dashboard:18889
OTEL_SERVICE_NAME=dmc-1-t1-notebook-api
